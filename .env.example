# =============================================================================
# 환경변수 예시 - 실제 배포 시 .env 파일로 복사 후 값을 입력하세요
# =============================================================================

# Redis (docker-compose 내부 네트워크)
REDIS_URL=redis://redis:6379/0

# RunPod Serverless
RUNPOD_API_URL=https://api.runpod.ai/v2/YOUR_ENDPOINT_ID
RUNPOD_API_KEY=your_runpod_api_key_here

# 임시 PDF URL 전달(EC2 공개 도메인/ALB 주소)
PUBLIC_BASE_URL=https://your-api-domain.com
TEMP_PDF_DIR=/app/tmp/pdfs
TEMP_PDF_TTL_SECONDS=600
TEMP_PDF_CLEANUP_INTERVAL_SECONDS=60
TEMP_PDF_SIGNING_KEY=your_temp_pdf_signing_key_here

# App
LOG_LEVEL=INFO

# JDPatent Internal API
JDPATENT_API_URL=http://jdpatent-api:8001
JDPATENT_SUBMIT_TIMEOUT_SECONDS=15
JDPATENT_POLL_TIMEOUT_SECONDS=900
JDPATENT_POLL_INTERVAL_SECONDS=2
